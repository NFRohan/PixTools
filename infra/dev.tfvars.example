environment = "dev"
aws_region  = "us-east-1"

# Replace with your current public IP/CIDR. Example:
# allowed_ingress_cidrs = ["203.0.113.10/32"]
allowed_ingress_cidrs = ["203.0.113.10/32"]

# Keep infra above the smallest burstable class; K3s control-plane and stateful services
# are not stable enough on t3.small once KEDA, Cluster Autoscaler, and broker state coexist.
# This AWS account rejected t3.medium launches, so m7i-flex.large is the supported baseline.
infra_instance_type = "m7i-flex.large"

# Pin workload compute to memory-optimized flex instances.
workload_instance_type = "m7i-flex.large"
workload_fallback_instance_types = []
workload_asg_min = 1
workload_asg_desired = 1
workload_asg_max = 4

# Recommended when the AWS account plan allows it:
# rds_instance_class = "db.t4g.small"

# Manifest sync prefix used by CD workflow.
manifest_s3_prefix = "manifests/dev"

# Optional email recipient for CloudWatch alarm notifications.
# alarm_email = "you@example.com"

# Grafana Cloud integration (Alloy exporter targets).
# grafana_cloud_stack_id    = "123456"
# grafana_cloud_logs_user   = "123456" # optional override
# grafana_cloud_metrics_user = "123456" # optional override
# grafana_cloud_traces_user = "123456" # optional override
# grafana_cloud_api_key     = "glc_..."
# grafana_cloud_logs_url    = "https://logs-prod-XXX.grafana.net/loki/api/v1/push"
# grafana_cloud_metrics_url = "https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push"
# grafana_cloud_traces_url  = "https://otlp-gateway-prod-us-east-0.grafana.net/otlp"
